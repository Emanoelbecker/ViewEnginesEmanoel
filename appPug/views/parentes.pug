extends layout

block content
  .container
    .card
      h2 Parentes dos Baiacus
      p Os baiacus pertencem à família Tetraodontidae e possuem vários parentes próximos em diferentes oceanos ao redor do mundo.
      img(src='/images/parentes.jpg', alt='Parentes dos Baiacus')
    .card
      h2 Espécies Relacionadas
      p Encontramos espécies similares em águas tropicais e temperadas, compartilhando características como a capacidade de inchar.
      img(src='/images/especies.jpg', alt='Espécies Relacionadas')
